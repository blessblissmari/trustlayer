# TrustLayer — backend environment variables
# Copy to backend/.env for local dev.

# AI mode: "yandex" (real YandexGPT) or "mock" (offline dev, default)
AI_MODE=mock

# YandexGPT configuration (required when AI_MODE=yandex)
# Get an API key: https://yandex.cloud/en/docs/iam/operations/api-key/create
YANDEX_API_KEY=
# Full model URI, e.g. gpt://<folder_id>/yandexgpt/latest or .../yandexgpt-lite/latest
YANDEX_GPT_MODEL=

# Storage backend: "memory" (ephemeral), "file" (local JSON, dev only), or "supabase"
# Default picks "supabase" automatically when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set.
STORAGE_BACKEND=
STORAGE_FILE_PATH=./data/reports.json

# Supabase (auth + persistent storage). Service-role key bypasses RLS — keep secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Free-tier daily analysis cap per user (enforced against Supabase `quotas` table)
FREE_TIER_DAILY_LIMIT=10

# Local dev server port (ignored when deployed as a Yandex Cloud Function)
PORT=8787

# Max characters of text we will send to the model / analyze per request
MAX_INPUT_CHARS=20000

# Max bytes to download when analyzing a URL
MAX_URL_BYTES=2000000

# CORS origin for the frontend (comma-separated, or "*" for dev)
CORS_ORIGIN=*
